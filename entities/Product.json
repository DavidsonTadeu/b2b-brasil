{
  "name": "Product",
  "type": "object",
  "properties": {
    "title": {
      "type": "string",
      "description": "Nome do produto"
    },
    "description": {
      "type": "string",
      "description": "Descri\u00e7\u00e3o t\u00e9cnica do produto"
    },
    "category": {
      "type": "string",
      "enum": [
        "Eletr\u00f4nicos",
        "T\u00eaxtil e Confec\u00e7\u00e3o",
        "M\u00e1quinas e Equipamentos",
        "Alimentos e Bebidas",
        "Embalagens",
        "Constru\u00e7\u00e3o Civil",
        "Automotivo",
        "Qu\u00edmicos",
        "M\u00f3veis e Decora\u00e7\u00e3o",
        "Sa\u00fade e Beleza",
        "Agroneg\u00f3cio",
        "Outros"
      ]
    },
    "price": {
      "type": "number",
      "description": "Pre\u00e7o unit\u00e1rio base em R$"
    },
    "price_tiers": {
      "type": "array",
      "description": "Faixas de pre\u00e7o por quantidade (atacado)",
      "items": {
        "type": "object",
        "properties": {
          "min_qty": {
            "type": "number",
            "description": "Quantidade m\u00ednima da faixa"
          },
          "max_qty": {
            "type": "number",
            "description": "Quantidade m\u00e1xima da faixa (null = ilimitado)"
          },
          "price": {
            "type": "number",
            "description": "Pre\u00e7o unit\u00e1rio nesta faixa"
          }
        }
      }
    },
    "min_order": {
      "type": "number",
      "description": "Pedido m\u00ednimo (unidades)",
      "default": 1
    },
    "stock": {
      "type": "number",
      "description": "Estoque dispon\u00edvel"
    },
    "images": {
      "type": "array",
      "items": {
        "type": "string"
      },
      "description": "URLs das imagens"
    },
    "variations": {
      "type": "array",
      "items": {
        "type": "object",
        "properties": {
          "name": {
            "type": "string"
          },
          "options": {
            "type": "array",
            "items": {
              "type": "string"
            }
          }
        }
      },
      "description": "Varia\u00e7\u00f5es do produto (cor, modelo, etc)"
    },
    "supplier_id": {
      "type": "string",
      "description": "ID do fornecedor"
    },
    "supplier_name": {
      "type": "string",
      "description": "Nome do fornecedor"
    },
    "status": {
      "type": "string",
      "enum": [
        "active",
        "inactive",
        "pending"
      ],
      "default": "active"
    },
    "tags": {
      "type": "array",
      "items": {
        "type": "string"
      }
    },
    "unit": {
      "type": "string",
      "enum": [
        "unidade",
        "caixa",
        "kg",
        "metro",
        "litro",
        "pacote"
      ],
      "default": "unidade"
    }
  },
  "required": [
    "title",
    "price",
    "category",
    "supplier_id"
  ]
}